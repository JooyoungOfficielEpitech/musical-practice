{
  "expo": {
    "name": "Musical Practice",
    "slug": "musical-practice",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "musicalpractice",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2444"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.musicalpractice",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Musical Practice needs microphone access to detect your pitch and measure accuracy while singing.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.musicalpractice",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#1B2444",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      [
        "expo-av",
        {
          "microphonePermission": "Musical Practice needs microphone access to detect your pitch and measure accuracy while singing."
        }
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "74be559c-56dd-48f6-ad27-c40c3f550dcd"
      }
    },
    "owner": "mmecoco"
  }
}
